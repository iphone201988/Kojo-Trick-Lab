<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <data>
     <variable
         name="vm"
         type="com.tech.kojo.ui.dashboard.home.progress.HomeProgressDetailsVM" />
    </data>
<androidx.core.widget.NestedScrollView
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">
    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/bg_color"
        tools:context=".ui.dashboard.home.progress.HomeProgressDetailsFragment">

        <androidx.viewpager2.widget.ViewPager2
            android:id="@+id/viewpager"
            android:layout_width="match_parent"
            android:layout_height="@dimen/_185sdp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

<!--        <androidx.media3.ui.PlayerView-->
<!--            android:id="@+id/localPlayerView"-->
<!--            android:layout_width="match_parent"-->
<!--            android:layout_height="@dimen/_200sdp"-->
<!--            android:visibility="gone"-->
<!--            app:use_controller="true"-->
<!--            app:layout_constraintStart_toStartOf="parent"-->
<!--            app:layout_constraintTop_toTopOf="parent" />-->

<!--        <androidx.appcompat.widget.AppCompatImageView-->
<!--            android:id="@+id/ivClosePlayer"-->
<!--            android:layout_width="@dimen/_28sdp"-->
<!--            android:layout_height="@dimen/_28sdp"-->
<!--            android:layout_margin="@dimen/_10sdp"-->
<!--            android:elevation="@dimen/_2sdp"-->
<!--            android:onClick="@{v->vm.onClick(v)}"-->
<!--            android:src="@drawable/baseline_cancel_24"-->
<!--            android:visibility="gone"-->
<!--            app:layout_constraintEnd_toEndOf="@+id/localPlayerView"-->
<!--            app:layout_constraintTop_toTopOf="@+id/localPlayerView"-->
<!--            app:tint="@color/white" />-->


        <FrameLayout
            android:id="@+id/flSubscription"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/_8sdp"
            app:layout_constraintBottom_toBottomOf="@+id/viewpager"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent">

            <com.zhpan.indicator.IndicatorView
                android:id="@+id/dotsIndicator"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:vpi_slider_checked_color="@color/blue"
                app:vpi_slider_normal_color="@color/colorPrimary" />
        </FrameLayout>

        <androidx.appcompat.widget.AppCompatImageView
            android:id="@+id/ivClosePlayer"
            android:layout_width="@dimen/_28sdp"
            android:layout_height="@dimen/_28sdp"
            android:layout_marginStart="@dimen/_10sdp"
            android:layout_marginTop="@dimen/_8sdp"
            android:src="@drawable/back"
            android:background="@drawable/yellow_bg"
            android:tint="@color/colorPrimary"
            android:backgroundTint="#80B0B0B0"
            android:onClick="@{v->vm.onClick(v)}"
            android:padding="@dimen/_5sdp"
           app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="@id/viewpager"/>
        <androidx.appcompat.widget.AppCompatTextView
            android:id="@+id/tvSkip"
            style="@style/TextView_700_Bold_Quicksand"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="@dimen/_5sdp"
            android:layout_marginTop="@dimen/_8sdp"
            android:gravity="start"
            android:maxLines="1"
            android:ellipsize="end"
            android:shadowColor="@color/black"
            android:shadowDx="3"
            android:shadowDy="3"
            android:shadowRadius="4"
            android:onClick="@{v->vm.onClick(v)}"
            android:paddingHorizontal="@dimen/_12sdp"
            android:paddingVertical="@dimen/_4sdp"
            android:textColor="@color/white"
            android:textSize="@dimen/_14ssp"
            app:layout_constraintEnd_toStartOf="@id/ivDownload"
            app:layout_constraintStart_toEndOf="@id/ivClosePlayer"
            app:layout_constraintTop_toTopOf="@+id/viewpager" />

        <LinearLayout
            android:id="@+id/ivDownload"
            android:layout_width="@dimen/_30sdp"
            android:layout_height="@dimen/_30sdp"
            android:layout_marginTop="@dimen/_8sdp"
            android:layout_marginEnd="@dimen/_6sdp"
            android:background="@drawable/yellow_bg"
            android:backgroundTint="#80B0B0B0"
            android:onClick="@{v->vm.onClick(v)}"
            android:gravity="center"
            app:layout_constraintTop_toTopOf="@id/viewpager"
            app:layout_constraintEnd_toStartOf="@id/ivFullscreen">
            <androidx.appcompat.widget.AppCompatImageView
                android:id="@+id/ivLoad"
                android:layout_width="@dimen/_20sdp"
                android:layout_height="@dimen/_20sdp"
                android:src="@drawable/ic_cloud_download"
                android:visibility="visible"
                />
        </LinearLayout>
        <LinearLayout
            android:id="@+id/ivFullscreen"
            android:layout_width="@dimen/_30sdp"
            android:layout_height="@dimen/_30sdp"
            android:layout_margin="@dimen/_8sdp"
            android:background="@drawable/yellow_bg"
            android:onClick="@{v->vm.onClick(v)}"
            android:backgroundTint="#80B0B0B0"
            android:gravity="center"
            app:layout_constraintTop_toTopOf="@id/viewpager"
            app:layout_constraintEnd_toEndOf="parent">
            <androidx.appcompat.widget.AppCompatImageView
                android:layout_width="@dimen/_24sdp"
                android:layout_height="@dimen/_24sdp"
                android:src="@drawable/maximize"
                android:tint="@color/colorPrimary"
                android:visibility="visible"
                />
        </LinearLayout>
        <androidx.appcompat.widget.AppCompatImageView
            android:id="@+id/ivProgress"
            android:layout_width="@dimen/_37sdp"
            android:layout_height="@dimen/_37sdp"
            android:scaleType="centerCrop"
            android:padding="@dimen/_10sdp"
            android:visibility="gone"
            android:onClick="@{v->vm.onClick(v)}"
            android:layout_marginEnd="@dimen/_10sdp"
            android:src="@drawable/close_icon"
            android:tint="@color/colorPrimary"
            app:layout_constraintBottom_toBottomOf="@+id/tvSkip"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@+id/tvSkip"
    />

        <androidx.appcompat.widget.AppCompatImageView
            android:id="@+id/ivMAx"
            android:layout_width="@dimen/_17sdp"
            android:layout_height="@dimen/_17sdp"
            android:scaleType="centerCrop"
            android:onClick="@{v->vm.onClick(v)}"
            android:visibility="gone"
            android:layout_marginEnd="@dimen/_16sdp"
            android:layout_marginBottom="@dimen/_5sdp"
            android:src="@drawable/maximize"
            app:layout_constraintBottom_toBottomOf="@+id/flSubscription"
            app:layout_constraintEnd_toEndOf="parent"
            />



        <androidx.appcompat.widget.AppCompatTextView
            android:id="@+id/tvTrack"
            style="@style/TextView_400_Regular"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/_18sdp"
            android:layout_marginTop="@dimen/_10sdp"
            android:layout_marginEnd="@dimen/_18sdp"
            android:paddingEnd="@dimen/_18sdp"
            android:textColor="@color/blue"
            android:textSize="@dimen/_11ssp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/viewpager" />


        <androidx.appcompat.widget.AppCompatTextView
            android:id="@+id/tvTricker"
            style="@style/TextView_600_SemiBold"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/_18sdp"
            android:layout_marginTop="@dimen/_4sdp"
            android:text="Prerequisites :"
            android:visibility="invisible"
            android:textSize="@dimen/_11ssp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/tvTrack" />
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvStep"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="@dimen/_15sdp"
            android:layout_marginTop="@dimen/_5sdp"
            android:clipToPadding="false"
            android:nestedScrollingEnabled="false"
            android:orientation="vertical"
            app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
            app:layout_constraintTop_toBottomOf="@+id/tvTricker"
            tools:itemCount="5"
            tools:listitem="@layout/step_rv_item" />

        <androidx.appcompat.widget.AppCompatTextView
            android:id="@+id/tvPhill"
            style="@style/TextView_400_Regular"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/_4sdp"
            android:visibility="gone"
            android:textColor="@color/blue"
            android:textSize="@dimen/_11ssp"
            app:layout_constraintBottom_toBottomOf="@+id/tvTricker"
            app:layout_constraintStart_toEndOf="@+id/tvTricker"
            app:layout_constraintTop_toTopOf="@+id/tvTricker" />


        <androidx.appcompat.widget.AppCompatTextView
            android:id="@+id/tvDirection"
            style="@style/TextView_600_SemiBold"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/_18sdp"
            android:layout_marginTop="@dimen/_10sdp"
            android:text="Direction toggle:"
            android:textColor="@color/blue"
            android:textSize="@dimen/_11ssp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/rvStep" />

        <androidx.appcompat.widget.AppCompatTextView
            android:id="@+id/tvLeft"
            style="@style/TextView_400_Regular"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/_4sdp"
            android:text="Left ↔ "
            android:textColor="@color/blue"
            android:textSize="@dimen/_11ssp"
            app:layout_constraintBottom_toBottomOf="@+id/tvDirection"
            app:layout_constraintStart_toEndOf="@+id/tvDirection"
            app:layout_constraintTop_toTopOf="@+id/tvDirection" />

        <androidx.appcompat.widget.AppCompatTextView
            android:id="@+id/tvRight"
            style="@style/TextView_600_SemiBold"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/_2sdp"
            android:text="Right"
            android:textColor="@color/colorPrimary"
            android:textSize="@dimen/_11ssp"
            app:layout_constraintBottom_toBottomOf="@+id/tvDirection"
            app:layout_constraintStart_toEndOf="@+id/tvLeft"
            app:layout_constraintTop_toTopOf="@+id/tvDirection" />

        <View
            android:layout_width="0dp"
            android:layout_height="@dimen/_1sdp"
            android:layout_marginTop="@dimen/_1sdp"
            android:background="@color/colorPrimary"
            app:layout_constraintEnd_toEndOf="@+id/tvRight"
            app:layout_constraintStart_toStartOf="@+id/tvRight"
            app:layout_constraintTop_toBottomOf="@+id/tvRight" />


        <View
            android:id="@+id/view"
            android:layout_width="0dp"
            android:layout_height="@dimen/_1sdp"
            android:layout_marginTop="@dimen/_18sdp"
            android:background="@color/blue_20"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/tvRight" />


        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvHomeProgressionDetails"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="@dimen/_14sdp"
            android:layout_marginTop="@dimen/_16sdp"
            android:clipToPadding="false"
            android:orientation="vertical"
            android:nestedScrollingEnabled="false"
            android:paddingBottom="@dimen/_15sdp"
            app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
            app:layout_constraintTop_toBottomOf="@+id/view"
            tools:itemCount="5"
            tools:listitem="@layout/progression_details_rv_item" />


        <androidx.appcompat.widget.AppCompatTextView
            android:id="@+id/btnMarkCompleted"
            style="@style/TextView_600_SemiBold_Quicksand"
            android:layout_width="match_parent"
            android:layout_height="@dimen/_44sdp"
            android:layout_marginHorizontal="@dimen/_18sdp"
            android:layout_marginBottom="@dimen/_12ssp"
            android:background="@drawable/btn_bg"
            android:backgroundTint="@color/grey_DDDDDD"
            android:gravity="center"
            android:visibility="gone"
            android:onClick="@{v->vm.onClick(v)}"
            android:text="@string/mark_completed"
            android:textColor="@color/white"
            android:textSize="@dimen/_15ssp"
            app:layout_constraintBottom_toTopOf="@+id/btnDownload"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent" />


        <androidx.appcompat.widget.AppCompatTextView
            android:id="@+id/btnDownload"
            style="@style/TextView_600_SemiBold_Quicksand"
            android:layout_width="0dp"
            android:layout_height="@dimen/_38sdp"
            android:layout_marginBottom="@dimen/_22ssp"
            android:background="@drawable/btn_bg"
            android:layout_marginEnd="@dimen/_6sdp"
            android:visibility="gone"
            android:backgroundTint="@color/colorPrimary"
            android:gravity="center"
            android:onClick="@{v->vm.onClick(v)}"
            android:text="@string/download"
            android:textColor="@color/white"
            android:textSize="@dimen/_15ssp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toStartOf="@+id/btnSave"
            app:layout_constraintStart_toStartOf="@+id/btnMarkCompleted" />

        <androidx.appcompat.widget.AppCompatTextView
            android:id="@+id/btnSave"
            style="@style/TextView_600_SemiBold_Quicksand"
            android:layout_width="0dp"
            android:layout_height="@dimen/_38sdp"
            android:background="@drawable/btn_bg"
            android:backgroundTint="@color/green_color"
            android:gravity="center"
            android:layout_marginStart="@dimen/_6sdp"
            android:onClick="@{v->vm.onClick(v)}"
            android:text="Save"
            android:textColor="@color/white"
            android:visibility="gone"
            android:textSize="@dimen/_15ssp"
            app:layout_constraintBottom_toBottomOf="@+id/btnDownload"
            app:layout_constraintTop_toTopOf="@+id/btnDownload"
            app:layout_constraintEnd_toEndOf="@+id/btnMarkCompleted"
            app:layout_constraintStart_toEndOf="@+id/btnDownload" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.core.widget.NestedScrollView>
</layout>